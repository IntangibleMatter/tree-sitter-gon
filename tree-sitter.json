{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "gon",
      "camelcase": "GON",
      "title": "GON",
      "scope": "source.gon",
      "file-types": [
        "gon"
      ],
      "injection-regex": "^gon$",
      "class-name": "TreeSitterGon"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "A tree-sitter parser for Glaiel Object Notation",
    "authors": [
      {
        "name": "IntangibleMatter",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/intangiblematter/tree-sitter-gon",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}